# 로컬 개발 — davinci-code-web/.env 로 복사 후 사용
# cp .env.example .env   (PowerShell: Copy-Item .env.example .env)

# PostgreSQL — 네이티브 설치 후 1회 설정
# 설치 시 정한 postgres 슈퍼유저 비밀번호로 교체
POSTGRES_ADMIN_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/postgres

# 앱 DB (npm run db:setup 이후 사용)
DATABASE_URL=postgresql://davinci:davinci@localhost:5432/davinci_dev

# v2 인증 (Phase B 이후 사용)
JWT_SECRET=change-me-in-local-dev-only

# 서버 (v1 호환 — 미설정 시 기본값)
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
PORT=3001

# 클라이언트 빌드/개발 (선택)
# VITE_SOCKET_URL=http://localhost:3001
