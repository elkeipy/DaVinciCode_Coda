{
  "name": "davinci-code-web",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "npm run build -w shared && npm run build -w server && npm run build -w client",
    "build:pages": "npm run build -w shared && npm run build:pages -w client",
    "db:up": "node scripts/db.mjs up",
    "db:down": "node scripts/db.mjs down",
    "db:logs": "node scripts/db.mjs logs",
    "db:ps": "node scripts/db.mjs ps",
    "db:setup": "node scripts/setup-native-db.mjs",
    "db:check": "node scripts/check-db.mjs",
    "db:push": "npm run db:push -w server",
    "test": "npm run test -w shared",
    "smoke:remote": "node scripts/smoke-remote.mjs",
    "smoke:pages": "node scripts/smoke-pages.mjs",
    "test:e2e": "npm run test:e2e -w client"
  },
  "devDependencies": {}
}
